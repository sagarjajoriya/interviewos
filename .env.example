# Which LLM provider to use. Registered in lib/llm/index.js.
# Swap to another vendor by adding an adapter + changing this value.
# "mock" = canned responses, zero API calls (UI development / tests).
LLM_PROVIDER=gemini

# Model id for the chosen provider (Gemini Flash by default).
LLM_MODEL=gemini-3.5-flash

# Provider credentials — set the one matching LLM_PROVIDER.
GEMINI_API_KEY=your_gemini_api_key_here
# GROQ_API_KEY=

# Storage: "sqlite" (default, persists to ./data/interviewos.db) or "memory".
# DB_DRIVER=sqlite
# DB_FILE=./data/interviewos.db
